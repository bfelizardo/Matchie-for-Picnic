rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isVerifiedEmail() {
      return isSignedIn();
    }

    function getUserEmail() {
      return request.auth.token.email.lower();
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/app_users/$(request.auth.token.email.lower())) &&
             get(/databases/$(database)/documents/app_users/$(request.auth.token.email.lower())).data.role == 'admin';
    }

    function isMember() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/app_users/$(request.auth.token.email.lower()));
    }

    function isFirstSetup() {
      return !exists(/databases/$(database)/documents/config/setup);
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---

    function isValidAppUser(data) {
      return data.role in ['admin', 'member'] && 
             (data.keys().hasAll(['role']) || data.keys().size() > 0);
    }

    function isValidItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
             && data.status in ["unmatched", "matching", "matched"]
             && data.count is number && data.count > 0
             && data.addedBy == getUserEmail();
    }

    // --- Collections ---

    match /app_users/{emailId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isVerifiedEmail() && isValidAppUser(incoming()) && (isFirstSetup() || isAdmin());
      allow update: if isVerifiedEmail() && isValidAppUser(incoming()) && isAdmin() &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['role', 'name']);
      allow delete: if isAdmin();
    }

    match /config/{configDoc} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isFirstSetup() || isAdmin());
      allow update: if isSignedIn() && (isFirstSetup() || isAdmin());
      allow delete: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if isMember();
      allow create: if isMember() && isValidItem(incoming());
      allow update: if isMember() && (
        // Only allow updating specific fields
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'count', 'matchedProduct', 'matchError', 'updatedAt'])
      );
      allow delete: if isMember();
    }

    match /shared_preferences/{prefId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    match /system/{id} {
      allow read: if isSignedIn();
    }
  }
}
